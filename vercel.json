{
    "version": 2,
    "builds": [
        {
            "src": "api/**/*.js",
            "use": "@vercel/node",
            "config": {
                "includeFiles": [
                    "lib/**"
                ]
            }
        },
        {
            "src": "src/**",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/favicon.ico",
            "dest": "/src/favicon.ico"
        },
        {
            "src": "/auth/google",
            "dest": "/api/auth/google.js"
        },
        {
            "src": "/auth/google/callback",
            "dest": "/api/auth/callback.js"
        },
        {
            "src": "/auth/logout",
            "dest": "/api/auth/logout.js"
        },
        {
            "src": "/auth/me",
            "dest": "/api/auth/me.js"
        },
        {
            "src": "/api/generate",
            "dest": "/api/generate.js"
        },
        {
            "src": "/api/config",
            "dest": "/api/config.js"
        },
        {
            "src": "/api/status",
            "dest": "/api/status.js"
        },
        {
            "src": "/main.js",
            "dest": "/src/main.js"
        },
        {
            "src": "/global.css",
            "dest": "/src/global.css"
        },
        {
            "src": "/(.*)",
            "dest": "/src/index.html"
        }
    ]
}